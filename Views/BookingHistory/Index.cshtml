@using Lab1_Project.Models
@model IEnumerable<BookingHistory>


<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold m-0">Історія активності</h2>
        </div>
    </div>

    <div class="d-grid gap-3"> 
        @foreach (var log in Model.OrderByDescending(l => l.ChangedAt)) {
            <div class="history-card p-4 border-0 shadow-sm rounded-4 position-relative overflow-hidden bg-white animate slideIn">
                <div class="status-indicator @(log.StatusToId == 2 ? "bg-success" : log.StatusToId == 3 ? "bg-danger" : "bg-warning")"></div>
                
                <div class="row align-items-center position-relative z-1">
                    <div class="col-md-8">
                        <div class="d-flex align-items-center mb-2">
                            <span class="badge-custom @(log.StatusToId == 2 ? "badge-success-soft" : log.StatusToId == 3 ? "badge-danger-soft" : "badge-warning-soft") me-3">
                                @log.StatusTo.StatusName
                            </span>
                            <h5 class="fw-bold mb-0">Бронювання кабінету @log.Booking.Workspace.Number</h5>
                        </div>
                        
                        <p class="mb-2 text-dark opacity-75 small">
                            <i class="bi bi-chat-left-quote me-2 text-muted"></i>
                            @(string.IsNullOrEmpty(log.ChangeReason) ? "Без коментарів" : log.ChangeReason)
                        </p>
                        
                        <div class="d-flex gap-3 mt-3">
                            <div class="small text-muted">
                                <i class="bi bi-person me-1"></i><strong>@(log.ChangedByUser?.FullName ?? "Система")</strong>
                            </div>
                            <div class="small text-muted">
                                <i class="bi bi-hash me-1"></i>ID: @log.BookingId
                            </div>
                        </div>
                    </div>
                    
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <div class="text-dark fw-bold small">@log.ChangedAt.ToString("dd MMM yyyy")</div>
                        <div class="text-muted small">@log.ChangedAt.ToString("HH:mm:ss")</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>