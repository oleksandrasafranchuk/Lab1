@model IEnumerable<Lab1_Project.Models.Booking>
@{
    var role = Context.Session.GetString("UserRole") ?? "User";
    ViewData["Title"] = "Бронювання";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Список бронювань</h2>
        <div class="text-muted small">Всього записів: @Model.Count()</div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light-soft">
                    <tr>
                        <th class="ps-4 py-3 border-0 text-uppercase small fw-bold">№ Кабінету</th>
                        @if (role == "Admin") { <th class="py-3 border-0 text-uppercase small fw-bold">Клієнт</th> }
                        <th class="py-3 border-0 text-uppercase small fw-bold">Час та період</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold">Сума</th>
                        <th class="py-3 border-0 text-uppercase small fw-bold">Статус</th>
                        <th class="pe-4 py-3 border-0 text-uppercase small fw-bold text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td class="ps-4">
                                <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-primary text-decoration-none">
                                    <i class="bi bi-door-open me-2"></i>@item.Workspace.Number
                                </a>
                            </td>
                            @if (role == "Admin") {
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-xs me-2">@item.User.FullName.Substring(0, 1)</div>
                                        <span>@item.User.FullName</span>
                                    </div>
                                </td>
                            }
                            <td>
                                <div class="small fw-semibold">@item.StartTime.ToString("dd MMM yyyy")</div>
                                <div class="text-muted small">@item.StartTime.ToString("HH:mm") — @item.EndTime.ToString("HH:mm")</div>
                            </td>
                            <td>
                                <span class="fw-bold text-dark">@item.TotalAmount ₴</span>
                            </td>
                            <td>
                                @{
                                    var badgeClass = item.StatusId == 2 ? "badge-success-soft" : 
                                                     item.StatusId == 3 ? "badge-danger-soft" : "badge-warning-soft";
                                }
                                <span class="badge-custom @badgeClass">
                                    <i class="bi bi-dot"></i> @item.Status.StatusName
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    @if (role == "Admin" && item.StatusId == 1) {
                                        <form asp-action="Approve" asp-route-id="@item.Id" method="post">
                                            <button class="btn btn-sm btn-success rounded-pill px-3 shadow-sm">
                                                Підтвердити
                                            </button>
                                        </form>
                                    }
                                    @if (item.StatusId != 3) {
                                        <button class="btn btn-sm btn-outline-danger rounded-pill px-3" 
                                                data-bs-toggle="modal" data-bs-target="#cancelModal-@item.Id">
                                            Скасувати
                                        </button>
                                        
                                        <div class="modal fade text-start" id="cancelModal-@item.Id" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <form asp-action="Cancel" asp-route-id="@item.Id" method="post" class="modal-content border-0 shadow rounded-4">
                                                    <div class="modal-header border-0">
                                                        <h5 class="fw-bold">Скасування бронювання</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <p class="text-muted small">Будь ласка, вкажіть причину скасування (необов'язково):</p>
                                                        <textarea name="reason" class="form-control rounded-3" rows="3" placeholder="Причина..."></textarea>
                                                    </div>
                                                    <div class="modal-footer border-0">
                                                        <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Назад</button>
                                                        <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">Скасувати</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-light rounded-pill px-3 border">
                                        Деталі
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>