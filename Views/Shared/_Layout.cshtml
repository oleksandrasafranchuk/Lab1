<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookingSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Lab1_Project.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg navbar-light bg-blur sticky-top py-4">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center me-5" asp-area="" asp-controller="Home" asp-action="Index">
                <span class="ms-3 fs-4">Booking<span class="text-primary">System</span></span>
            </a>
            
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-4 align-items-center">
                    <li class="nav-item">
                        <a class="nav-link px-4 py-2 d-flex align-items-center" asp-controller="Workspaces" asp-action="Index">
                            <i class="bi bi-geo-alt me-2 text-primary"></i> @(Context.Session.GetString("UserRole") == "Admin" ? "Робочі місця" : "Знайти місце")
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-4 py-2 d-flex align-items-center" asp-controller="Bookings" asp-action="Index">
                            <i class="bi bi-calendar-event me-2 text-primary"></i> Бронювання
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-4 py-2 d-flex align-items-center" asp-controller="BookingHistory" asp-action="Index">
                            <i class="bi bi-clock-history me-2 text-primary"></i> Історія
                        </a>
                    </li>
                    
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        
                        <li class="nav-item">
                            <a class="nav-link px-4 py-2 d-flex align-items-center" asp-controller="WorkspaceTypes" asp-action="Index">
                                <i class="bi bi-grid-1x2 me-2 text-primary"></i> Типи
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-semibold px-4 py-2 d-flex align-items-center" asp-controller="Statistics" asp-action="Index">
                                <i class="bi bi-bar-chart-line me-2"></i> Статистика
                            </a>
                        </li>
                    }

                    <li class="nav-item dropdown ms-lg-4">
                        <a class="nav-link dropdown-toggle btn btn-user d-flex align-items-center gap-3 shadow-sm border py-2 ps-2 pe-4" 
                           href="#" id="userMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="avatar-md shadow-sm">
                                @(Context.Session.GetString("UserRole")?.Substring(0, 1) ?? "G")
                            </div>
                            <span class="fw-bold">@(Context.Session.GetString("UserRole") ?? "Гість")</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 p-2 animate slideIn">
                            <li><a class="dropdown-item rounded-2 py-2" href="/Home/SetRole?role=Admin&id=1"><i class="bi bi-shield-lock me-2"></i> Адмін</a></li>
                            <li><a class="dropdown-item rounded-2 py-2" href="/Home/SetRole?role=User&id=2"><i class="bi bi-person me-2"></i> Юзер</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger rounded-2 py-2" href="/Home/SetRole?role=&id="><i class="bi bi-box-arrow-right me-2"></i> Вийти</a></li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

        <main role="main" class="container pb-3 animate slideIn">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center">
            &copy; 2026 - BookingSystem. Всі права захищені.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>