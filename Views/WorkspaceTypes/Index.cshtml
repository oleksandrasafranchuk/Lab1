@model IEnumerable<Lab1_Project.Models.WorkspaceType>
@{ 
    var role = Context.Session.GetString("UserRole") ?? "User"; 
    ViewData["Title"] = "Типи приміщень";
}

<div class="container mt-5">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow border-0 rounded-4 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-exclamation-octagon-fill fs-4 me-3"></i>
                <div>@TempData["Error"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        TempData["Error"] = null;
    }

    <div class="d-flex justify-content-between align-items-center mb-5">
        <div-group>
            <h2 class="fw-bold m-0">Типи приміщень</h2>
            
        </div-group>
        
        @if(role == "Admin") { 
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm hover-lift">
                <i class="bi bi-plus-circle me-2"></i>Додати новий тип
            </a> 
        }
    </div>
    
    <div class="row g-3">
        @foreach(var item in Model) {
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 p-2 transition-all hover-shadow">
                    <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                        <div class="d-flex align-items-center">
                            <div class="icon-square bg-primary bg-opacity-10 text-primary me-4">
                                <i class="bi bi-collection"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-1">@item.TypeName</h5>
                                <p class="text-muted small mb-0">
                                    <i class="bi bi-info-circle me-1"></i>
                                    @(string.IsNullOrEmpty(item.Description) ? "Опис поки що відсутній для цього типу." : item.Description)
                                </p>
                            </div>
                        </div>
                        
                        @if(role == "Admin") {
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 border-0 bg-light-soft text-dark">
                                    <i class="bi bi-pencil-square me-1"></i> Редагувати
                                </a>

                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" 
                                      onsubmit="return confirm('Ви впевнені? Це може вплинути на існуючі місця!')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 border-0 bg-light-soft">
                                        <i class="bi bi-trash3 me-1"></i> Видалити
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>