@model Lab1_Project.Models.Workspace
@{
    ViewData["Title"] = "Деталі місця " + Model.Number;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden animate slideIn">
                <div class="row g-0">
                    <div class="col-md-5 bg-dark-gradient d-flex align-items-center justify-content-center p-5 text-white">
                        <div class="text-center">
                            <div class="mb-3">
                                <i class="bi bi-display fs-1 opacity-50"></i>
                            </div>
                            <h1 class="display-1 fw-bold mb-0">@Model.Number</h1>
                            <div class="mt-3">
                                <span class="badge rounded-pill bg-primary px-4 py-2 shadow-sm">
                                    <i class="bi bi-tag-fill me-2"></i>@Model.Type.TypeName
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-7 bg-white">
                        <div class="card-body p-5">
                            <div class="d-flex justify-content-between align-items-start mb-4">
                                <h2 class="fw-bold m-0">Детальна інформація</h2>
                                <a asp-action="Index" class="btn btn-light btn-sm rounded-circle shadow-sm" title="Назад">
                                    <i class="bi bi-x-lg"></i>
                                </a>
                            </div>
                            
                            <div class="mb-5">
                                <h6 class="text-uppercase text-muted small fw-bold ls-1 mb-3">
                                    <i class="bi bi-info-circle me-2"></i>Опис приміщення
                                </h6>
                                <p class="text-secondary lh-lg mb-0">
                                    @(string.IsNullOrEmpty(Model.Type.Description) 
                                        ? "Для цього типу приміщення опис ще не додано. Ви можете уточнити деталі у адміністратора." 
                                        : Model.Type.Description)
                                </p>
                            </div>

                            <div class="row g-4 mb-5">
                                <div class="col-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-square bg-light text-primary me-3">
                                            <i class="bi bi-wifi"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block">Інтернет</small>
                                            <span class="fw-bold small">Wi-Fi 6</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-square bg-light text-primary me-3">
                                            <i class="bi bi-plug"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block">Живлення</small>
                                            <span class="fw-bold small">220V + USB</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4 opacity-50">

                            <div class="d-flex justify-content-between align-items-center mb-5">
                                <div>
                                    <h6 class="text-uppercase text-muted small fw-bold ls-1 mb-1">Вартість</h6>
                                    <span class="h2 text-success fw-bold mb-0">@Model.PricePerHour ₴</span>
                                    <small class="text-muted">/ год</small>
                                </div>
                                <div class="text-end">
                                    <h6 class="text-uppercase text-muted small fw-bold ls-1 mb-1">Доступність</h6>
                                    @if(Model.IsActive) {
                                        <span class="badge-custom badge-success-soft py-2 px-3 fs-6">
                                            <i class="bi bi-check-circle-fill me-2"></i>Активне
                                        </span>
                                    } else {
                                        <span class="badge-custom badge-danger-soft py-2 px-3 fs-6">
                                            <i class="bi bi-dash-circle-fill me-2"></i>Неактивне
                                        </span>
                                    }
                                </div>
                            </div>

                            <div class="row g-3">
                                <div class="col-sm-8">
                                    @if(Model.IsActive) {
                                        <a asp-controller="Bookings" asp-action="Create" asp-route-workspaceId="@Model.Id" 
                                           class="btn btn-primary btn-lg w-100 py-3 rounded-3 shadow hover-lift">
                                            <i class="bi bi-calendar-plus me-2"></i>Забронювати зараз
                                        </a>
                                    } else {
                                        <button class="btn btn-secondary btn-lg w-100 py-3 rounded-3 shadow" disabled>
                                            Тимчасово недоступне
                                        </button>
                                    }
                                </div>
                                <div class="col-sm-4">
                                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg w-100 py-3 rounded-3">
                                        Назад
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>