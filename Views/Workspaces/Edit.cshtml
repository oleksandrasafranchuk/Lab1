@model Lab1_Project.Models.Workspace

@{
    ViewData["Title"] = "Редагування " + Model.Number;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden animate slideIn">
                <div class="row g-0">
                    <div class="col-md-4 bg-dark-gradient d-flex align-items-center justify-content-center p-5 text-white">
                        <div class="text-center">
                            <div class="icon-circle bg-primary bg-opacity-25 mb-4 mx-auto">
                                <i class="bi bi-pencil-square fs-1 text-primary"></i>
                            </div>
                            <h2 class="fw-bold">Редагування</h2>
                            <p class="text-muted small">Оновіть параметри робочого місця @Model.Number для коректного бронювання користувачами.</p>
                            <hr class="my-4 opacity-25">
                            <div class="small">
                                <i class="bi bi-clock-history me-2"></i>Створено: <br>
                                <span class="text-white-50">@Model.CreatedAt.ToString("g")</span>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8 bg-white">
                        <div class="card-body p-5">
                            <form asp-action="Edit">
                                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small" role="alert"></div>
                                <input type="hidden" asp-for="Id" />
                                <input type="hidden" asp-for="CreatedAt" />

                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <label asp-for="Number" class="form-label small fw-bold text-muted text-uppercase">Номер або назва</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-hash"></i></span>
                                            <input asp-for="Number" class="form-control border-0 bg-light shadow-none py-2" placeholder="напр. A-101" />
                                        </div>
                                        <span asp-validation-for="Number" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-6">
                                        <label asp-for="TypeId" class="form-label small fw-bold text-muted text-uppercase">Тип приміщення</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-layers"></i></span>
                                            <select asp-for="TypeId" class="form-select border-0 bg-light shadow-none py-2" asp-items="ViewBag.TypeId"></select>
                                        </div>
                                        <span asp-validation-for="TypeId" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12">
                                        <label asp-for="PricePerHour" class="form-label small fw-bold text-muted text-uppercase">Ціна за годину (₴)</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-0"><i class="bi bi-currency-dollar"></i></span>
                                            <input asp-for="PricePerHour" class="form-control border-0 bg-light shadow-none py-2" type="number" step="0.01" />
                                        </div>
                                        <span asp-validation-for="PricePerHour" class="text-danger small"></span>
                                    </div>

                                    <div class="col-12">
                                        <div class="form-check form-switch p-3 bg-light rounded-3 d-flex align-items-center justify-content-between">
                                            <label class="form-check-label fw-bold ms-5 mb-0" for="isActiveSwitch">Доступне для бронювання</label>
                                            <input asp-for="IsActive" class="form-check-input ms-0 mt-0" type="checkbox" role="switch" id="isActiveSwitch" style="width: 3rem; height: 1.5rem;">
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-5 d-flex gap-3">
                                    <button type="submit" class="btn btn-primary btn-lg px-5 py-3 rounded-3 shadow hover-lift flex-grow-1">
                                        <i class="bi bi-check2-circle me-2"></i>Зберегти зміни
                                    </button>
                                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 py-3 rounded-3">
                                        Скасувати
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>